{
  "manifest_version": 3,
  "name": "YT Paid Promotion Flagger",
  "version": "1.0.0",
  "description": "Walks through every video in YouTube Studio and turns ON the 'My video contains paid promotion' flag.",
  "permissions": ["scripting", "storage", "tabs"],
  "host_permissions": ["https://studio.youtube.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YT Paid Promotion Flagger",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://studio.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
